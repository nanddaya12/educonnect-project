{
  "name": "educonnect",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd frontend && npm run dev",
    "install-all": "npm install && cd server && npm install && cd ../frontend && npm install"
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}
