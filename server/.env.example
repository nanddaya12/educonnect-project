# EduConnect Server Environment Configuration

# Server running port
PORT=5000

# Node operating environment (development / production)
NODE_ENV=production

# MongoDB Database URI (Local / Atlas)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/educonnect
MONGO_URI=mongodb://localhost:27017/educonnect

# JWT Signing Secret (Cryptographically secure 64-byte hex string)
JWT_SECRET=8f4e2c9b1d0a6e7f3b2c1a0d9e8f7a6b5c4d3e2f1a0b9c8d7e6f5a4b3c2d1e0f8f4e2c9b1d0a6e7f3b2c1a0d9e8f7a6b5c4d3e2f1a0b9c8d7e6f5a4b3c2d1e0f

# JWT lifetime (e.g. 7d, 12h)
JWT_EXPIRES_IN=7d
